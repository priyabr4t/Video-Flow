generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id          String      @id @default(cuid())
  status      VideoStatus @default(QUEUED)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  originalKey String?
  p360Key     String?
  p720Key     String?
  p1080Key    String?
}

enum VideoStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  UPLOADING
}

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id String @id @default(cuid())

  originalKey String?

  status VideoStatus @default(QUEUED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum VideoStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}
